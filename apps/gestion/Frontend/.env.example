# Leave empty in local dev: Vite proxies /auth, /admin/permissions, /health to gestion-api (port 8003).
# Only set a full URL for Docker/production builds.
VITE_API_URL=
# VITE_API_URL=http://127.0.0.1:8003

# Auth mode: local (dev form) | sso (Centrale redirect)
VITE_AUTH_MODE=local

# SSO logout redirect (AUTH_MODE=sso)
# VITE_CENTRALE_HOME_URL=https://app.prysme.eu

# Local dev port (default: 3002)
PORT=3002
