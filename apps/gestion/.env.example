# MongoDB (same cluster, two databases — see root .env.example)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_COWORK=cowork_bdd
MONGODB_DB_PRYSMA=prysma_bdd

# Local dev port (default: 3001)
PORT=3001

# Public site URL (required in production for env validation)
NEXT_PUBLIC_SITE_URL=http://localhost:3001
