# MongoDB — utilisateur applicatif (readWrite cowork_bdd, read prysma_bdd)
MONGODB_URI="mongodb://coworkprysme_app:CHANGE_ME@127.0.0.1:27017/?authSource=admin&directConnection=true"
MONGODB_DB_COWORK=cowork_bdd
MONGODB_DB_PRYSMA=prysma_bdd

# CORS — include 127.0.0.1 when using SSH port forwarding (localhost ≠ 127.0.0.1 for browsers)
ALLOWED_ORIGIN=http://localhost:3002,http://127.0.0.1:3002,http://localhost:8002

# Auth — local mode verifies credentials read-only against prysma_bdd.users
AUTH_MODE=local
SESSION_SECRET=CHANGE_ME_USE_AT_LEAST_32_RANDOM_CHARACTERS
SESSION_TTL_HOURS=4
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# SSO mode only (AUTH_MODE=sso)
# CENTRALE_API_URL=https://app.prysme.eu/api
# CENTRALE_HOME_URL=https://app.prysme.eu

# Local dev port (default: 8003)
PORT=8003
