# MongoDB — utilisateur applicatif (readWrite cowork_bdd, read prysma_bdd)
MONGODB_URI="mongodb://coworkprysme_app:CHANGE_ME@127.0.0.1:27017/?authSource=admin&replicaSet=rs0"
MONGODB_DB_COWORK=cowork_bdd
MONGODB_DB_PRYSMA=prysma_bdd

# CORS — include 127.0.0.1 when using SSH port forwarding (localhost ≠ 127.0.0.1 for browsers)
ALLOWED_ORIGIN=http://localhost:3002,http://127.0.0.1:3002,http://localhost:8002

# Auth — local mode verifies credentials read-only against prysma_bdd.users
AUTH_MODE=local
SESSION_SECRET=CHANGE_ME_USE_AT_LEAST_32_RANDOM_CHARACTERS
SESSION_TTL_HOURS=4
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# SSO mode only (AUTH_MODE=sso)
# CENTRALE_API_URL=https://app.prysme.eu/api
# CENTRALE_HOME_URL=https://app.prysme.eu

# Local dev port (default: 8003)
PORT=8003

# SMTP (optional) — confirmation emails after mark-transfer-received (dry-run if unset)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM_ADDRESS=noreply@prysme.eu
# SMTP_FROM_NAME=Cowork Prysme

# Qonto Business API (optional — bank-transfer reconciliation suggestions, read-only)
# All of CLIENT_ID / CLIENT_SECRET / REDIRECT_URI / TOKEN_ENCRYPTION_KEY required together.
# Sandbox also requires QONTO_STAGING_TOKEN (Developer Portal).
# QONTO_ENV=sandbox
# QONTO_CLIENT_ID=
# QONTO_CLIENT_SECRET=
# QONTO_STAGING_TOKEN=
# QONTO_REDIRECT_URI=http://localhost:8003/integrations/qonto/callback
# QONTO_TOKEN_ENCRYPTION_KEY=  # ≥32 random chars
# QONTO_BANK_ACCOUNT_ID=       # optional; auto-discovered from /v2/organization
# QONTO_POLL_INTERVAL_MS=600000

# Building photos — local dev defaults to {repo}/uploads (gitignored)
# UPLOADS_DIR=/data/uploads
# UPLOAD_MAX_BYTES=5242880
# UPLOAD_MAX_PHOTOS_PER_BUILDING=15
# UPLOAD_MAX_DIMENSION_PX=2048

# Invoice PDF attachment (Phase 2 — same INVOICE_ISSUER_* as vitrine-api)
# INVOICE_ISSUER_LEGAL_NAME=
# INVOICE_ISSUER_LEGAL_FORM=
# INVOICE_ISSUER_SHARE_CAPITAL=
# INVOICE_ISSUER_ADDRESS_LINE1=
# INVOICE_ISSUER_ADDRESS_LINE2=
# INVOICE_ISSUER_SIRET=
# INVOICE_ISSUER_VAT_NUMBER=
# INVOICE_ISSUER_RCS=
# INVOICE_ISSUER_EMAIL=
# INVOICE_ISSUER_PHONE=
# Optional: BANK_TRANSFER_* also used on PDF RIB block when method=bank_transfer

# Stripe refunds (Planning Wave 3) — MUST be the SAME account+mode as vitrine-api
# STRIPE_SECRET_KEY (PaymentIntents are created there). Use sk_test_… for proofs.
# STRIPE_SECRET_KEY=
# Webhook endpoint: POST /stripe/webhook (forward with: stripe listen --forward-to localhost:8003/stripe/webhook)
# STRIPE_WEBHOOK_SECRET=
