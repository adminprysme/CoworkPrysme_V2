# MongoDB (cowork read-only for public BFF)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_COWORK=cowork_bdd

# CORS — comma-separated browser origins (no wildcards)
ALLOWED_ORIGIN=http://localhost:3001

# gestion-api base URL (server-side delegation stub)
GESTION_API_URL=http://localhost:8003

# Local dev port (default: 8002)
PORT=8002
