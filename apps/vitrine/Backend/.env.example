# MongoDB (cowork only — utilisateur applicatif, pas root)
MONGODB_URI="mongodb://coworkprysme_app:CHANGE_ME@127.0.0.1:27017/?authSource=admin&replicaSet=rs0"
MONGODB_DB_COWORK=cowork_bdd

# CORS — comma-separated browser origins (no wildcards)
ALLOWED_ORIGIN=http://localhost:3001

# gestion-api base URL (server-side delegation stub)
GESTION_API_URL=http://localhost:8003

# Local dev port (default: 8002)
PORT=8002

# Public site origin for links in transactional emails (/contact, privacy policy)
# PUBLIC_SITE_URL=https://coworkprysme.eu

# TEMPORARY — staff booking notification until Permissions module exists.
# Sole consumer: resolveBookingNotificationRecipients(). Never use buildings.email as recipient.
# FALLBACK_BOOKING_NOTIFICATION_EMAIL=staff@example.com

# Stripe (Phase 4a — card payment). Optional for boot; required to create PaymentIntents / receive webhooks.
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# Local webhook: stripe listen --forward-to localhost:8002/stripe/webhook

# Bank transfer (virement) — company RIB + eligibility thresholds.
# Required to offer bank_transfer in the booking tunnel.
# BANK_TRANSFER_IBAN=FR76...
# BANK_TRANSFER_BIC=XXXXFRPP
# BANK_TRANSFER_ACCOUNT_HOLDER=Cowork Prysme
# BANK_TRANSFER_BANK_NAME=Qonto
# BANK_TRANSFER_MIN_LEAD_DAYS=7
# BANK_TRANSFER_PAYMENT_WINDOW_DAYS=8
# BANK_TRANSFER_SAFETY_MARGIN_DAYS=2

# Shared uploads volume (read-only mount on vitrine-api in production)
# UPLOADS_DIR=/data/uploads
