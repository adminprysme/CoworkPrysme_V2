# MongoDB (cowork only — utilisateur applicatif, pas root)
MONGODB_URI="mongodb://coworkprysme_app:CHANGE_ME@127.0.0.1:27017/?authSource=admin&directConnection=true"
MONGODB_DB_COWORK=cowork_bdd

# CORS — comma-separated browser origins (no wildcards)
ALLOWED_ORIGIN=http://localhost:3001

# gestion-api base URL (server-side delegation stub)
GESTION_API_URL=http://localhost:8003

# Local dev port (default: 8002)
PORT=8002

# Shared uploads volume (read-only mount on vitrine-api in production)
# UPLOADS_DIR=/data/uploads
