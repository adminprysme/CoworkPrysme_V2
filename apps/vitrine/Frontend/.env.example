# Public site URL (required in production)
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# gestion-web login URL base (vitrine CTAs)
NEXT_PUBLIC_GESTION_WEB_URL=http://localhost:3002

# vitrine-api base URL (browser-side fetch)
NEXT_PUBLIC_API_URL=http://localhost:8002

# Stripe publishable key (Payment Element). Never use the secret key here.
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Local dev port (default: 3001)
PORT=3001
